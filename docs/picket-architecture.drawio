<mxfile host="app.diagrams.net" version="24.0.0">
  <diagram id="picket-arch" name="Picket architecture">
    <mxGraphModel dx="1500" dy="950" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="950" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="bg_machine" value="Local machine (POSIX) — fork / setsid" style="rounded=1;dashed=1;fillColor=none;strokeColor=#999999;html=1;verticalAlign=top;align=left;spacingLeft=8;spacingTop=4;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="120" y="110" width="1320" height="810" as="geometry" />
        </mxCell>
        <mxCell id="bg_store" value="Flat-file store — $PICKET_HOME&#10;(sole coordination medium · no DB / no queue · atomic writes)" style="rounded=1;fillColor=#f5f5f5;strokeColor=#999999;html=1;verticalAlign=top;align=center;spacingTop=4;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="520" y="250" width="300" height="470" as="geometry" />
        </mxCell>
        <mxCell id="bg_runtime" value="Runtime — one detached daemon per active watch" style="rounded=1;dashed=1;fillColor=none;strokeColor=#82b366;html=1;verticalAlign=top;align=center;spacingTop=4;fontColor=#2d6a2d;" vertex="1" parent="1">
          <mxGeometry x="880" y="255" width="340" height="330" as="geometry" />
        </mxCell>

        <mxCell id="internet" value="Internet / external APIs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="610" y="30" width="240" height="50" as="geometry" />
        </mxCell>

        <mxCell id="actor" value="Actor (you)" style="shape=umlActor;html=1;verticalLabelPosition=bottom;labelPosition=center;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="150" y="440" width="40" height="80" as="geometry" />
        </mxCell>

        <mxCell id="claude" value="Claude Code session&#10;(MCP client · controller)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="240" y="300" width="210" height="70" as="geometry" />
        </mxCell>
        <mxCell id="mcp" value="Picket MCP server&#10;FastMCP · stdio · control plane&#10;arm · register · list · stop · pause · audit&#10;(short-lived; may die with the session)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="240" y="470" width="210" height="120" as="geometry" />
        </mxCell>

        <mxCell id="f_state" value="watches/&lt;id&gt;.json — daemon-owned state" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#bbbbbb;align=left;spacingLeft=6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="540" y="300" width="260" height="48" as="geometry" />
        </mxCell>
        <mxCell id="f_ctl" value="watches/&lt;id&gt;.control — server→daemon cmd" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#bbbbbb;align=left;spacingLeft=6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="540" y="356" width="260" height="48" as="geometry" />
        </mxCell>
        <mxCell id="f_rb" value="runbooks/&lt;id&gt;/ — runbook.toml + entry" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#bbbbbb;align=left;spacingLeft=6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="540" y="412" width="260" height="48" as="geometry" />
        </mxCell>
        <mxCell id="f_pr" value="probes/&lt;id&gt;/ — probe.toml + script" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#bbbbbb;align=left;spacingLeft=6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="540" y="468" width="260" height="48" as="geometry" />
        </mxCell>
        <mxCell id="f_fire" value="fires/&lt;id&gt;.jsonl — audit (append-only)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#bbbbbb;align=left;spacingLeft=6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="540" y="524" width="260" height="48" as="geometry" />
        </mxCell>
        <mxCell id="f_log" value="logs/&lt;id&gt;.log — rotating poll log" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#bbbbbb;align=left;spacingLeft=6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="540" y="580" width="260" height="48" as="geometry" />
        </mxCell>
        <mxCell id="f_lock" value="locks/&lt;id&gt;.lock — in-flight flock" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#bbbbbb;align=left;spacingLeft=6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="540" y="636" width="260" height="48" as="geometry" />
        </mxCell>

        <mxCell id="daemon" value="Detached daemon&#10;python -m picket.daemon &lt;id&gt;&#10;double-fork + setsid → survives session&#10;poll loop · heartbeat · verify-before-kill" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="900" y="290" width="300" height="110" as="geometry" />
        </mxCell>
        <mxCell id="cond" value="Condition source (exactly one):&#10;(a) HTTP endpoint + JSONPath predicate&#10;(b) probe script → {fire, value, payload}&#10;observe-error ⇒ never fires" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="900" y="410" width="300" height="78" as="geometry" />
        </mxCell>
        <mxCell id="gating" value="Gating: rising-edge / once-per-episode · debounce · cooldown · in-flight lock · max_fires · ttl · active-window" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="900" y="498" width="300" height="72" as="geometry" />
        </mxCell>

        <mxCell id="handler" value="Ephemeral handler — one runbook, then exits&#10;prompt: scoped `claude -p` (--allowedTools)&#10;exec: script (no LLM, no tokens)&#10;supervised: timeout · retry→dead-letter · drift · notify" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="900" y="630" width="300" height="120" as="geometry" />
        </mxCell>
        <mxCell id="work" value="Event-driven work&#10;MCP servers (mcp__*) · skills · side effects" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="900" y="790" width="300" height="55" as="geometry" />
        </mxCell>

        <mxCell id="e_actor_claude" value="drives" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="actor" target="claude">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_claude_mcp" value="stdio · MCP tools" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;startArrow=block;endArrow=block;" edge="1" parent="1" source="claude" target="mcp">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_mcp_store" value="register: write *.toml&#10;arm: write state · ctl: write .control&#10;audit: read fires / logs" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="mcp" target="bg_store">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_mcp_daemon" value="arm → spawn (detached)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;endArrow=open;" edge="1" parent="1" source="mcp" target="daemon">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_daemon_store" value="single-writer:&#10;state · fires · log&#10;reads .control / loop" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;startArrow=block;endArrow=block;" edge="1" parent="1" source="daemon" target="bg_store">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_net_daemon" value="HTTP (auth_ref secret = env-var name)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;startArrow=block;endArrow=block;" edge="1" parent="1" source="cond" target="internet">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_daemon_handler" value="on satisfied edge&#10;(post-gating) → launch" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="gating" target="handler">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_handler_daemon" value="stdout / exit code →&#10;daemon writes fire record" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;endArrow=open;" edge="1" parent="1" source="handler" target="daemon">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_handler_work" value="uses mcp__* / Skill&#10;(per allowlist)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="handler" target="work">
          <mxGeometry relative="1" as="geometry" />
